planet_superdove/
planet_superdove_BACKUP_2026020*/
planet_superdove_landmasked/
planet_superdove_old/
planet_superdove_oldv2/

# ---------- Other large data folders ----------
datasets/
data/
!data/splits/
coral_masks/
land_mask/
do not use/
model_states/

# ---------- Model checkpoints ----------
*.pt

# ---------- Zip / tar archives ----------
*.zip
*.tar
*.tar.gz
*.tgz

# ---------- Image / raster data ----------
*.TIF
*.tif
*.tiff
*.jpg
*.jpeg
*.bmp
*.gif
*.npy
*.npz

# ---------- Jupyter / Notebook ----------
.ipynb_checkpoints/
**/.ipynb_checkpoints/
*.nbconvert.*
Untitled*.ipynb

# ---------- Wandb ----------
wandb/

# ---------- Python / Conda / Venv ----------
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.so
venv/
env/
.env/
.venv/

# ---------- Logs & slurm ----------
*.log
*.out
*.err
slurm-*.out

# ---------- OS / IDE ----------
.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~

# ---------- Other large/binary ----------
*.h5
*.hdf5
